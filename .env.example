# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://memora_user:memora_password@localhost:5432/memora_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Storage ───────────────────────────────────────────────────────────────────
# Set this to your external hard disk path, e.g. E:\Memora or /mnt/external/memora
MEDIA_ROOT=E:\Memora

# Root drive/folder to mount for "Import from disk" feature
# Set to whatever drive your photos live on, e.g. D:\ or C:\Users\Karthik\Photos
IMPORT_ROOT=D:\

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
